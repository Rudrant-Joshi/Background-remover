# ========================
# SnapCut AI — Environment Variables
# ========================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=snapcut_temp

# n8n Webhooks
VITE_N8N_PROCESS_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/process-image
VITE_N8N_RAZORPAY_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/razorpay-payment
VITE_N8N_CREATE_ORDER_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/create-order

# Razorpay
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# AI API (choose one)
# Remove.bg
VITE_AI_PROVIDER=removebg
VITE_REMOVEBG_API_KEY=your-removebg-api-key

# ClipDrop (alternative)
# VITE_AI_PROVIDER=clipdrop
# VITE_CLIPDROP_API_KEY=your-clipdrop-api-key

# Photoroom (alternative)
# VITE_AI_PROVIDER=photoroom
# VITE_PHOTOROOM_API_KEY=your-photoroom-api-key

# App Config
VITE_APP_NAME=SnapCut AI
VITE_APP_URL=https://snapcut.ai
VITE_FREE_DAILY_LIMIT=5
VITE_MAX_FILE_SIZE_MB=10
